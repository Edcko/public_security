{
  "name": "public_security",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:setup": "tsx scripts/run-migrations.ts",
    "db:reset": "docker-compose exec postgres psql -U admin -d public_security -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && npm run db:setup",
    "env:check": "tsx scripts/check-env.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:ps": "docker-compose ps",
    "docker:restart": "docker-compose restart",
    "docker:rebuild": "docker-compose up -d --build",
    "worker:reports": "tsx src/workers/scheduled-reports-worker.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.978.0",
    "@types/nodemailer": "^7.0.9",
    "@types/qrcode": "^1.5.6",
    "amqplib": "^0.10.9",
    "authenticator": "^1.1.5",
    "axios": "^1.13.4",
    "bcrypt": "^5.1.1",
    "casbin": "^5.48.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^5.10.0",
    "next": "16.1.6",
    "nodemailer": "^7.0.13",
    "otplib": "^13.2.1",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^4.7.1",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "totp": "^0.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/otplib": "^7.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^5.0.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
