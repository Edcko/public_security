# Database
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/public_security

# JWT Secrets
JWT_SECRET=CHANGE_ME_GENERATE_A_SECURE_RANDOM_STRING
REFRESH_TOKEN_SECRET=CHANGE_ME_GENERATE_A_SECURE_RANDOM_STRING

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Email Configuration (SMTP)
# Para desarrollo, puedes usar Gmail con App Password
# Para producción, usar Sendgrid, AWS SES, o tu propio SMTP server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
EMAIL_FROM="Sistema de Gestión Policial" <noreply@policia.gob.mx>

# Opciones SMTP comunes:
# Gmail: smtp.gmail.com:587
# Sendgrid: smtp.sendgrid.net:587
# AWS SES: email-smtp.us-east-1.amazonaws.com:587
# Mailgun: smtp.mailgun.org:587

# Redis (opcional, para cache y sessions)
REDIS_URL=redis://localhost:6379

# S3/Cloud Storage (opcional, para archivos y fotos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Google Maps API (opcional, para mapas)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Facial Recognition (opcional)
FACIAL_RECOGNITION_API_KEY=
FACIAL_RECOGNITION_PROVIDER=aws  # aws, google, azure

# Monitoring (opcional)
SENTRY_DSN=
