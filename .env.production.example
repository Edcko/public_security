# Environment Variables para Producción
# Copiar este archivo a .env.production y llenar con los valores reales

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/public_security

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://admin:password@localhost:5672

# Mapbox (GIS/Mapping)
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# APIs Mexicanas
VERIFICAMEX_API_KEY=your-verificamex-api-key
VERIFICAMEX_API_URL=https://api.verificamex.com/api/v1
LLAVE_MX_API_KEY=your-llave-mx-api-key
LLAVE_MX_API_URL=https://api.gob.mx/llavemx

# SNSP
SNSP_DATA_URL=https://www.gob.mx/sesnsp/acciones-y-programas/datos-abiertos-de-incidencia-delictiva

# Email (para reportes agendados)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# App Configuration
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_WS_URL=wss://your-domain.com
NODE_ENV=production

# Monitoring (opcional)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info
